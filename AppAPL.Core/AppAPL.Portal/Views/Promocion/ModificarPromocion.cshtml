@* ~/Views/Promocion/ModificarPromocion.cshtml *@
@{
    ViewData["Title"] = "Modificación de Promociones";
    var usuarioActual = ViewBag.UsuarioActual as string;
}

@section Scripts {
    <script>window.usuarioActual = '@usuarioActual';</script>
    <script src="~/js/jquery-3.7.1.min.js" asp-append-version="true"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.3/themes/base/jquery-ui.css">
    <script src="https://code.jquery.com/ui/1.13.3/jquery-ui.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.3/i18n/datepicker-es.js"></script>
    <script src="~/js/datatables.min.js" asp-append-version="true"></script>
    <script src="~/js/Promocion/ModificarPromocion.js" asp-append-version="true"></script>
}

<link rel="stylesheet" href="~/css/datatables.css" asp-append-version="true" />

<style>
    .ui-datepicker {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        font-size: 0.9rem;
        z-index: 1056 !important;
    }

    #dvPromocionGeneral .form-control, #dvPromocionGeneral .form-select {
        font-size: 0.8rem;
        height: 31px;
    }

    #dvPromocionGeneral .form-label {
        font-size: 0.78rem;
        margin-bottom: 2px;
    }

    #dvPromocionGeneral .input-group-text {
        font-size: 0.8rem;
        padding: 0.25rem 0.5rem;
    }

    #dvPromocionGeneral .btn-outline-secondary {
        font-size: 0.78rem;
        padding: 0.25rem 0.4rem;
        border-color: #6c757d;
    }

        #dvPromocionGeneral .btn-outline-secondary img {
            width: 14px;
            height: 14px;
        }

    .promo-top-row {
        border-bottom: 1px solid #dee2e6;
        padding-bottom: 8px;
        margin-bottom: 4px;
    }

        .promo-top-row .input-group-text {
            font-weight: 700;
            font-size: 0.82rem;
        }

    .seg-input-group .btn {
        padding: 0.25rem 0.35rem;
        line-height: 1;
    }

        .seg-input-group .btn i {
            font-size: 0.75rem;
        }

    .soporte-section {
        border-top: 1px solid #dee2e6;
        padding-top: 8px;
        margin-top: 6px;
    }

        .soporte-section .btn-buscar {
            font-size: 0.78rem;
            padding: 4px 10px;
            white-space: nowrap;
        }

        .soporte-section .soporte-nombre {
            font-size: 0.78rem;
            background: #e9ecef;
        }

    .regalo-check-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 31px;
    }

        .regalo-check-container input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: #0d6efd;
            cursor: pointer;
        }

    .articulo-group .input-group-text {
        padding: 0.25rem 0.4rem;
    }

    .articulo-group .form-check-input {
        width: 14px;
        height: 14px;
        margin: 0;
        cursor: pointer;
    }

    .btn-success-custom {
        background-color: #198754;
        color: white;
        border-color: #198754;
        font-size: 0.78rem;
        padding: 0.25rem 0.4rem;
    }

    .label-una-linea {
        white-space: nowrap;
        font-size: 0.68rem !important;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        width: 100%;
    }

    input:disabled, select:disabled {
        background-color: #e9ecef !important;
        color: #6c757d !important;
        cursor: not-allowed !important;
        opacity: 1;
    }

    /* ESTILOS TABLA ARTÍCULOS */
    .detalle-header {
        background-color: #343a40;
        color: white;
        padding: 6px 15px;
        text-align: center;
        font-weight: bold;
        font-size: 0.95rem;
        border-radius: 4px;
    }

    .tabla-items-header th {
        background-color: #a4c995;
        color: #343a40;
        font-weight: bold;
        vertical-align: middle;
        text-align: center;
        border: 1px solid #dee2e6;
        font-size: 0.75rem;
    }

    .custom-header-cons-bg {
        background-color: #a4c995 !important;
        color: #343a40 !important;
    }

    .custom-header-ingr-bg {
        background-color: #FFEC99 !important;
        color: #343a40 !important;
    }

    .custom-header-calc-bg {
        background-color: #FFBF47 !important;
        color: #343a40 !important;
    }

    .tabla-items-body input[type="text"], .tabla-items-body input[type="number"] {
        text-align: right;
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
        height: 28px;
        border: 1px solid #ced4da;
        border-radius: 0.2rem;
    }

    .tabla-items-body td {
        font-size: 0.78rem;
        vertical-align: middle;
    }

    .table-sticky-col {
        position: sticky;
        left: 0;
        background-color: #fff;
        z-index: 1;
    }

    thead .table-sticky-col {
        z-index: 2;
    }

    .modal-pantalla-completa {
        max-width: 95vw !important;
        width: 95vw !important;
    }

    /* MODAL VISOR PDF */
    #modalVisorPdf .modal-dialog {
        max-width: 90vw;
        height: 90vh;
    }

    #modalVisorPdf .modal-content {
        height: 90vh;
        display: flex;
        flex-direction: column;
    }

    #modalVisorPdf .modal-header {
        background: #1a237e;
        color: #fff;
        padding: 8px 16px;
        border-bottom: none;
    }

        #modalVisorPdf .modal-header .btn-close {
            filter: invert(1);
        }

    #modalVisorPdf .modal-body {
        padding: 0;
        display: flex;
        flex-direction: column;
        flex: 1;
        overflow: hidden;
    }

    #modalVisorPdf .modal-footer {
        padding: 6px 16px;
        border-top: 1px solid #ddd;
        background: #f8f8f8;
    }

    #pdfVisorContenido {
        flex: 1;
        width: 100%;
        height: 100%;
    }

    #pdfIframe {
        width: 100%;
        height: 100%;
        border: none;
        background: #525659;
        display: block;
    }

    #pdfSpinner {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        height: 100%;
        background: #525659;
        color: #fff;
    }

    #pdfVisorError {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        height: 100%;
        background: #f8d7da;
        color: #842029;
        font-size: 0.9rem;
        padding: 20px;
        text-align: center;
    }
</style>

<h2>Modificación - Promociones</h2>
<hr class="separador-fondos" />

<div id="vistaTabla" class="table-responsive">
    <div id="tabla"></div>
</div>

<div id="vistaDetalle" style="display:none;">
    <div class="card border-secondary mb-3">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-dark">Modificar Promoción #<span id="lblIdPromocion"></span></h5>
            <button type="button" class="btn btn-sm btn-outline-dark" id="btnVolverTabla"><i class="fa-solid fa-arrow-left"></i> Volver a la Bandeja</button>
        </div>

        <div class="card-body p-3">
            <input type="hidden" id="modalPromocionId">
            <input type="hidden" id="modalTipoPromocion">

            <div id="dvPromocionGeneral">
                <div class="row g-1 promo-top-row justify-content-between">
                    <div class="col">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text">Promoción</span>
                            <input type="text" class="form-control" id="verPromocionHeader" readonly>
                        </div>
                    </div>
                    <div class="col-auto">
                        <div class="input-group input-group-sm mb-1">
                            <span class="input-group-text">No. Promoción</span>
                            <input type="text" class="form-control text-center" id="verPromocionNum" style="max-width: 100px;" readonly>
                        </div>
                    </div>
                </div>

                <form id="formPromocion" class="row g-2 mt-1">
                    <div class="col-md-3 text-center">
                        <label for="promocionDescripcion" class="form-label fw-bold col-form-label-sm">Descripción</label>
                        <input type="text" class="form-control form-control-sm" id="promocionDescripcion" placeholder="Descripción de promoción" maxlength="200">
                    </div>
                    <div class="col-md-2 text-center">
                        <label for="promocionMotivo" class="form-label fw-bold col-form-label-sm">Motivo</label>
                        <select id="promocionMotivo" class="form-select form-select-sm"><option value="">Cargando...</option></select>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="form-label fw-bold col-form-label-sm">Inicio: Fecha - Hora</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control form-control-sm" id="promocionFechaInicio" placeholder="dd/mm/aaaa">
                            <input type="time" class="form-control form-control-sm" id="promocionHoraInicio" value="00:00">
                            <button class="btn btn-outline-secondary" type="button" id="btnFechaInicio"><i class="fa-regular fa-calendar"></i></button>
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="form-label fw-bold col-form-label-sm">Fin: Fecha - Hora</label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control form-control-sm" id="promocionFechaFin" placeholder="dd/mm/aaaa">
                            <input type="time" class="form-control form-control-sm" id="promocionHoraFin" value="23:59">
                            <button class="btn btn-outline-secondary" type="button" id="btnFechaFin"><i class="fa-regular fa-calendar"></i></button>
                        </div>
                    </div>
                    <div class="col-md-1 text-center">
                        <label class="form-label fw-bold col-form-label-sm">Estado</label>
                        <input type="text" class="form-control form-control-sm" id="verEstadoPromocion" readonly disabled>
                    </div>

                    <div id="seccionGeneralSegmentos">
                        <div class="row g-2">
                            <div class="col-md-2 text-center">
                                <label class="form-label fw-bold col-form-label-sm">Marca</label>
                                <div class="input-group input-group-sm seg-input-group">
                                    <button id="btnMarca" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalMarca"><i class="fa-solid fa-list-check"></i></button>
                                    <select id="segMarca" class="form-select form-select-sm"><option value="" selected>Todas</option></select>
                                </div>
                            </div>
                            <div class="col-md-2 text-center">
                                <label class="form-label fw-bold col-form-label-sm">División</label>
                                <div class="input-group input-group-sm seg-input-group">
                                    <button id="btnDivision" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalDivision"><i class="fa-solid fa-list-check"></i></button>
                                    <select id="segDivision" class="form-select form-select-sm"><option value="" selected>Todas</option></select>
                                </div>
                            </div>
                            <div class="col-md-2 text-center">
                                <label class="form-label fw-bold col-form-label-sm">Departamento</label>
                                <div class="input-group input-group-sm seg-input-group">
                                    <button id="btnDepartamento" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalDepartamento"><i class="fa-solid fa-list-check"></i></button>
                                    <select id="segDepartamento" class="form-select form-select-sm"><option value="" selected>Todos</option></select>
                                </div>
                            </div>
                            <div class="col-md-2 text-center">
                                <label class="form-label fw-bold col-form-label-sm">Clase</label>
                                <div class="input-group input-group-sm seg-input-group">
                                    <button id="btnClase" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalClase"><i class="fa-solid fa-list-check"></i></button>
                                    <select id="segClase" class="form-select form-select-sm"><option value="" selected>Todas</option></select>
                                </div>
                            </div>
                            <div class="col-md-4 text-center">
                                <label class="form-label fw-bold col-form-label-sm">Artículo</label>
                                <div class="input-group input-group-sm articulo-group">
                                    <div class="input-group-text"><input class="form-check-input mt-0" type="checkbox" id="chkArticulo"></div>
                                    <input type="text" class="form-control" id="segArticulo" disabled>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="seccionArticuloSegmentos" style="display:none;"></div>

                    <div class="col-md-3 text-center">
                        <label class="form-label fw-bold col-form-label-sm">Canal</label>
                        <div class="input-group input-group-sm seg-input-group">
                            <button id="btnCanal" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalCanal"><i class="fa-solid fa-list-check"></i></button>
                            <select class="form-select form-select-sm" id="segCanal"><option value="" selected>Todos</option></select>
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="form-label fw-bold col-form-label-sm">Grupo</label>
                        <div class="input-group input-group-sm seg-input-group">
                            <button id="btnGrupoAlmacen" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalGrupoAlmacen"><i class="fa-solid fa-list-check"></i></button>
                            <select class="form-select form-select-sm" id="segGrupoAlmacen"><option value="" selected>Todos</option></select>
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="form-label fw-bold col-form-label-sm">Almacén</label>
                        <div class="input-group input-group-sm seg-input-group">
                            <button id="btnAlmacen" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalAlmacen"><i class="fa-solid fa-list-check"></i></button>
                            <select class="form-select form-select-sm" id="segAlmacen"><option value="" selected>Todos</option></select>
                        </div>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="form-label fw-bold col-form-label-sm">Tipo de Cliente</label>
                        <div class="input-group input-group-sm seg-input-group">
                            <button id="btnTipoCliente" class="btn btn-outline-secondary d-none" type="button" data-bs-toggle="modal" data-bs-target="#ModalClientesEspecificos"><i class="fa-solid fa-list-check"></i></button>
                            <select class="form-select form-select-sm" id="segTipoCliente"><option value="" selected>Todos</option></select>
                        </div>
                    </div>

                    <div id="seccionGeneralAcuerdos" class="row g-2">
                        <div class="col-md-1 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="% Dscto Prov.">% Dscto Prov.</label>
                            <input type="text" class="form-control form-control-sm text-end" id="descuentoProveedor" placeholder="0.00">
                        </div>
                        <div class="col-md-3 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="ID Acuerdo Prov.">ID Acuerdo Prov.</label>
                            <div class="input-group input-group-sm">
                                <input type="hidden" id="fondoProveedorId"><input type="hidden" id="fondoDisponibleProv">
                                <input type="text" class="form-control" id="fondoProveedorText" placeholder="Selec..." readonly>
                                <button class="btn btn-outline-secondary" type="button" id="btnBuscarProv" data-bs-toggle="modal" data-bs-target="#modalConsultaProveedor" title="Buscar Acuerdo"><i class="fa-solid fa-magnifying-glass"></i></button>
                                <button class="btn btn-outline-danger" type="button" id="btnBorrarProv" title="Quitar Selección"><i class="fa-solid fa-eraser"></i></button>
                            </div>
                        </div>
                        <div class="col-md-1 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="$ Compr. Prov.">$ Compr. Prov.</label>
                            <input type="text" class="form-control form-control-sm text-end" id="fondoValorTotal" placeholder="0.00">
                        </div>
                        <div class="col-md-1 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="% Dscto Propio">% Dscto Propio</label>
                            <input type="text" class="form-control form-control-sm text-end" id="descuentoPropio" placeholder="0.00">
                        </div>
                        <div class="col-md-3 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="ID Acuerdo Propio">ID Acuerdo Propio</label>
                            <div class="input-group input-group-sm">
                                <input type="hidden" id="acuerdoPropioId"><input type="hidden" id="acuerdoPropioDisponible">
                                <input type="text" class="form-control" id="acuerdoPropioText" placeholder="Selec..." readonly>
                                <button class="btn btn-outline-secondary" type="button" id="btnBuscarPropio" data-bs-toggle="modal" data-bs-target="#modalConsultaAcuerdoPropio" title="Buscar Acuerdo"><i class="fa-solid fa-magnifying-glass"></i></button>
                                <button class="btn btn-outline-danger" type="button" id="btnBorrarPropio" title="Quitar Selección"><i class="fa-solid fa-eraser"></i></button>
                            </div>
                        </div>
                        <div class="col-md-1 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="$ Compr. Propio">$ Compr. Propio</label>
                            <input type="text" class="form-control form-control-sm text-end" id="comprometidoPropio" placeholder="0.00">
                        </div>
                        <div class="col-md-1 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="% Dscto Total">% Dscto Total</label>
                            <input type="text" class="form-control form-control-sm text-end" id="descuentoTotal" placeholder="0.00" readonly disabled>
                        </div>
                        <div class="col-md-1 text-center px-1">
                            <label class="form-label fw-bold label-una-linea" title="Regalo">Regalo</label>
                            <div class="regalo-check-container"><input class="form-check-input" type="checkbox" id="promocionMarcaRegalo"></div>
                        </div>
                    </div>

                    <div class="col-12 soporte-section">
                        <div class="row align-items-center g-1">
                            <div class="col-auto"><label class="form-label fw-bold col-form-label-sm mb-0">Adjuntar Documento Soporte</label></div>
                            <div class="col">
                                <div class="input-group input-group-sm">
                                    <label class="btn btn-secondary btn-sm soporte-buscar mb-0" for="inputArchivoSoporte" style="cursor:pointer; line-height: 1.5;">Buscar Archivo</label>
                                    <input type="file" id="inputArchivoSoporte" class="d-none" accept="@ViewBag.ExtensionesPermitidas" data-max-mb="@ViewBag.MaximoTamanoMB">
                                    <span class="form-control" id="lblArchivoActual">Ningún archivo seleccionado</span>
                                    <button class="btn btn-outline-secondary" type="button" id="btnVerSoporteActual" title="Ver Documento"><i class="fa-regular fa-file-lines"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="seccionArticuloDetalle" class="col-12" style="display:none;">
                        <div class="detalle-header mt-2"><i class="fa-solid fa-boxes-stacked me-1"></i> Detalle de los Artículos</div>
                        <div class="d-flex align-items-center gap-3 pt-2 pb-1">
                            <button id="btnAddItemArticulos" type="button" class="btn btn-outline-primary border-0 d-flex align-items-center gap-1" data-bs-toggle="modal" data-bs-target="#modalConsultaItems"><i class="fa-regular fa-square-plus"></i> Añadir</button>
                            <button id="btnDeleteItemArticulos" type="button" class="btn btn-outline-danger border-0 d-flex align-items-center gap-1"><i class="fa-regular fa-trash-can"></i> Eliminar</button>
                            <button id="btnEquivalentes" type="button" class="btn btn-outline-secondary border-0 d-flex align-items-center gap-1"><i class="fa-solid fa-arrows-left-right"></i> Equivalentes</button>
                            <button id="btnPreciosCompetencia" type="button" class="btn btn-outline-secondary border-0 d-flex align-items-center gap-1"><i class="fa-solid fa-tags"></i> Precios Competencia</button>
                            <button id="btnOtrosCostos" type="button" class="btn btn-outline-secondary border-0 d-flex align-items-center gap-1"><i class="fa-solid fa-coins"></i> Otros Costos</button>
                        </div>
                        <div class="col-12">
                            <div class="table-responsive small border" style="height: 350px; overflow: auto;">
                                <table class="table table-bordered table-sm">
                                    <thead class="sticky-top text-nowrap">
                                        <tr class="text-center tabla-items-header">
                                            <th style="width: 40px; background-color: #a4c995;">Sel.</th>
                                            <th class="table-sticky-col custom-header-cons-bg" style="min-width: 200px;">Artículo</th>
                                            <th class="custom-header-cons-bg">Costo</th>
                                            <th class="custom-header-cons-bg">Stock Bodega</th>
                                            <th class="custom-header-cons-bg">Stock Tienda</th>
                                            <th class="custom-header-cons-bg">Inv. Óptimo</th>
                                            <th class="custom-header-cons-bg">Excedente(u)</th>
                                            <th class="custom-header-cons-bg">Excedente($)</th>
                                            <th class="custom-header-cons-bg">Vta M-0(u)</th>
                                            <th class="custom-header-cons-bg">Vta M-0($)</th>
                                            <th class="custom-header-cons-bg">Vta M-1(u)</th>
                                            <th class="custom-header-cons-bg">Vta M-1($)</th>
                                            <th class="custom-header-cons-bg">Vta M-2(u)</th>
                                            <th class="custom-header-cons-bg">Vta M-2($)</th>
                                            <th class="custom-header-cons-bg">Vta M-12(u)</th>
                                            <th class="custom-header-cons-bg">Vta M-12($)</th>
                                            <th class="custom-header-cons-bg">Vta Igualar</th>
                                            <th class="custom-header-cons-bg">Dias Igualar</th>
                                            <th class="custom-header-cons-bg">Marg.Min Contado</th>
                                            <th class="custom-header-cons-bg">Marg.Min TC</th>
                                            <th class="custom-header-cons-bg">Marg.Min Crédito</th>
                                            <th class="custom-header-cons-bg">Marg.Min Igualar</th>
                                            <th class="custom-header-ingr-bg">Unidades Límite</th>
                                            <th class="custom-header-ingr-bg">Proyección Vtas(u)</th>
                                            <th class="custom-header-ingr-bg">Medio de Pago</th>
                                            <th class="custom-header-cons-bg">Precio Lista Contado</th>
                                            <th class="custom-header-cons-bg">Precio Lista Crédito</th>
                                            <th class="custom-header-ingr-bg">Precio Promo Contado</th>
                                            <th class="custom-header-ingr-bg">Precio Promo TC</th>
                                            <th class="custom-header-ingr-bg">Precio Promo Crédito</th>
                                            <th class="custom-header-ingr-bg">Precio Igualar</th>
