@* ~/Views/Promocion/AprobarPromocion.cshtml *@
@{
    ViewData["Title"] = "Aprobación de Promociones";
    var usuarioActual = ViewBag.UsuarioActual as string;
}

@section Scripts {
    <script>
        window.usuarioActual = '@usuarioActual';
    </script>
    <script src="~/js/jquery-3.7.1.min.js" asp-append-version="true"></script>
    <script src="~/js/Promocion/AprobarPromocion.js" asp-append-version="true"></script>
    <script src="~/js/datatables.min.js" asp-append-version="true"></script>
}

<link rel="stylesheet" href="~/css/datatables.css" asp-append-version="true" />

<h2>Aprobar - Promociones</h2>
<hr class="separador-fondos" />

<div id="vistaTabla" class="table-responsive">
    <div id="tabla"></div>
</div>

<div id="vistaDetalle" style="display:none;">
    <div class="card border-secondary mb-3">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-dark">Detalle de la Promoción #<span id="lblIdPromocion"></span></h5>
            <button type="button" class="btn btn-sm btn-outline-dark" id="btnVolverTabla">
                <i class="fa-solid fa-arrow-left"></i> Volver a la Bandeja
            </button>
        </div>

        <div class="card-body p-2">
            <form id="formVisualizar">

                <div class="promo-form-grid">
                    <div class="promo-header-row">
                        <span class="promo-label">Promoción</span>
                        <input type="text" class="promo-id-input" id="verPromocionHeader" readonly>
                        <div class="promo-icons">
                            <div class="promo-icon-btn text-danger" id="btnVerSoporte" title="Ver Soporte" style="cursor:pointer;">
                                <i class="fa-regular fa-file-pdf"></i>
                            </div>
                        </div>
                    </div>
                    <div class="promo-section">
                        <div class="promo-col"><div class="promo-col-header">Descripción</div><div class="promo-col-value"><input type="text" id="verDescripcion" readonly></div></div>
                        <div class="promo-col col-md"><div class="promo-col-header">Motivo</div><div class="promo-col-value"><input type="text" id="verMotivo" readonly></div></div>
                        <div class="promo-col col-md"><div class="promo-col-header">Inicio: Fecha - Hora</div><div class="promo-col-value"><input type="text" id="verFechaInicio" readonly></div></div>
                        <div class="promo-col col-md"><div class="promo-col-header">Fin: Fecha - Hora</div><div class="promo-col-value"><input type="text" id="verFechaFin" readonly></div></div>
                        <div class="promo-col col-md"><div class="promo-col-header">Estado</div><div class="promo-col-value"><input type="text" id="verEstado" readonly></div></div>
                    </div>
                </div>

                <div id="seccion-detalle-general" style="display:none;">
                    <div class="promo-form-grid mt-2">
                        <div class="promo-section">
                            <div class="promo-col"><div class="promo-col-header">Marca</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerMarca" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verMarca" readonly></div></div></div>
                            <div class="promo-col"><div class="promo-col-header">División</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerDivision" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verDivision" readonly></div></div></div>
                            <div class="promo-col"><div class="promo-col-header">Departamento</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerDepartamento" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verDepartamento" readonly></div></div></div>
                            <div class="promo-col"><div class="promo-col-header">Clase</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerClase" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verClase" readonly></div></div></div>
                            <div class="promo-col col-md"><div class="promo-col-header">Artículo</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerArticuloGen" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verArticulo" readonly></div></div></div>
                        </div>
                        <div class="promo-section">
                            <div class="promo-col"><div class="promo-col-header">Canal</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerCanalGen" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verCanal" readonly></div></div></div>
                            <div class="promo-col"><div class="promo-col-header">Grupo</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerGrupoAlmacenGen" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verGrupoAlmacen" readonly></div></div></div>
                            <div class="promo-col"><div class="promo-col-header">Almacén</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerAlmacenGen" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verAlmacen" readonly></div></div></div>
                            <div class="promo-col"><div class="promo-col-header">Tipo de Cliente</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerTipoClienteGen" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verTipoCliente" readonly></div></div></div>
                            <div class="promo-col"><div class="promo-col-header">Medio Pago</div><div class="promo-col-value"><div class="input-with-icon"><button type="button" id="btnVerMedioPagoGen" class="icon-btn"><i class="fa-solid fa-list-check"></i></button><input type="text" id="verMedioPago" readonly></div></div></div>
                        </div>
                        <div class="promo-section">
                            <div class="promo-col"><div class="promo-col-header" style="white-space: nowrap; text-align: center;">% Dscto Prov.</div><div class="promo-col-value"><input type="text" id="verDsctoProv" readonly></div></div>
                            <div class="promo-col"><div class="promo-col-header" style="white-space: nowrap;">ID Acuerdo Proveedor</div><div class="promo-col-value"><div class="input-with-icon"><span class="icon-btn"><i class="fa-solid fa-magnifying-glass"></i></span><input type="text" id="verIdAcuerdoProv" readonly></div></div></div>
                            <div class="promo-col col-md"><div class="promo-col-header" style="white-space: nowrap; text-align: center;">$ Comprometido Proveed.</div><div class="promo-col-value"><input type="text" id="verComprometidoProv" readonly></div></div>
                            <div class="promo-col"><div class="promo-col-header" style="white-space: nowrap; text-align: center;">% Dscto Prop.</div><div class="promo-col-value"><input type="text" id="verDsctoProp" readonly></div></div>
                            <div class="promo-col"><div class="promo-col-header" style="white-space: nowrap;">ID Acuerdo Propio</div><div class="promo-col-value"><div class="input-with-icon"><span class="icon-btn"><i class="fa-solid fa-magnifying-glass"></i></span><input type="text" id="verIdAcuerdoProp" readonly></div></div></div>
                            <div class="promo-col col-md"><div class="promo-col-header" style="white-space: nowrap; text-align: center;">$ Comprometido Propio</div><div class="promo-col-value"><input type="text" id="verComprometidoProp" readonly></div></div>
                            <div class="promo-col"><div class="promo-col-header" style="white-space: nowrap; text-align: center;">% Dscto Total</div><div class="promo-col-value"><input type="text" id="verDsctoTotal" readonly></div></div>
                            <div class="promo-col col-xs"><div class="promo-col-header" style="text-align: center;">Regalo</div><div class="promo-col-value center-value"><input type="checkbox" id="verRegalo" onclick="return false;"></div></div>
                        </div>
                    </div>
                </div>

                <div id="seccion-detalle-articulos" style="display:none;">
                    <div class="row g-1 mt-2">
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Canal</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerCanalArt" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verCanalArt" readonly disabled>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Grupo Almacén</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerGrupoAlmacenArt" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verGrupoAlmacenArt" readonly disabled>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Almacén</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerAlmacenArt" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verAlmacenArt" readonly disabled>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Tipo de Cliente</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerTipoClienteArt" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verTipoClienteArt" readonly disabled>
                            </div>
                        </div>
                    </div>

                    <div class="detalle-header-articulos mt-3">
                        <i class="fa-solid fa-boxes-stacked me-1"></i> Detalle de los Artículos
                    </div>
                </div>

                <div id="seccion-detalle-combos" style="display:none;">
                    <div class="row g-1 mt-2">
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Canal</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerCanalComb" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verCanalComb" readonly disabled>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Grupo Almacén</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerGrupoAlmacenComb" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verGrupoAlmacenComb" readonly disabled>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Almacén</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerAlmacenComb" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verAlmacenComb" readonly disabled>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold col-form-label-sm mb-0">Tipo de Cliente</label>
                            <div class="input-group input-group-sm">
                                <button id="btnVerTipoClienteComb" class="btn btn-outline-secondary btn-sm d-none" type="button">
                                    <i class="fa-solid fa-list-check"></i>
                                </button>
                                <input type="text" class="form-control form-control-sm" id="verTipoClienteComb" readonly disabled>
                            </div>
                        </div>
                    </div>

                    <div class="detalle-header-articulos mt-3" style="background-color: #343a40;">
                        <i class="fa-solid fa-layer-group me-1"></i> Detalle de los Combos
                    </div>
                </div>

                <div class="col-12 mt-2" id="contenedor-tabla-articulos" style="display:none;"></div>
                <div class="col-12 mt-2" id="contenedor-tabla-combos" style="display:none;"></div> <div class="col-12 mt-2" id="contenedor-tabla-combos-completa" style="display:none;"></div> <hr class="mt-3 mb-2" />

                <div class="custom-form-row mt-4">
                    <div class="custom-form-col w-100 p-2" style="background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 4px;">
                        <label class="form-label fw-bold col-form-label-sm" for="modal-promocion-comentario">
                            <i class="fa-solid fa-comment-dots text-primary"></i> Comentario de Aprobación/Rechazo:
                        </label>
                        <textarea class="form-control" rows="3" maxlength="200" id="modal-promocion-comentario" name="comentario" placeholder="Escribe aquí el motivo de aprobación o rechazo..."></textarea>
                    </div>
                </div>
            </form>
            <hr class="mt-3 mb-2" />
            <h5 class="custom-section-title mt-3 mb-3" style="font-size: 1.05rem; font-weight: bold; color: #1a237e;">
                <i class="fa-solid fa-list-check text-primary"></i> Historial de Aprobaciones
            </h5>
            <div class="custom-table-container mb-3">
                <div id="tabla-aprobaciones-promocion"></div>
            </div>
        </div>

        <div class="card-footer d-flex justify-content-end gap-2">
            <button type="button" class="btn btn-secondary btn-uniforme" id="btnVolverAbajo">
                Cancelar
            </button>
            <button type="button" class="custom-btn-danger btn-uniforme" id="btnRechazarPromocion">
                <i class="fa-solid fa-circle-xmark custom-btn-icon"></i> Rechazar
            </button>
            <button type="button" class="custom-btn-primary btn-uniforme" id="btnAprobarPromocion">
                <i class="fa-solid fa-circle-check custom-btn-icon"></i> Aprobar
            </button>
        </div>
    </div>
</div>

<div class="modal fade" id="modalVerSegmento" tabindex="-1" aria-labelledby="modalVerSegmentoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="modalVerSegmentoLabel">Elementos Seleccionados</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="row m-2" id="bodyModalVerSegmento">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalVisorPdf" tabindex="-1" aria-labelledby="modalVisorPdfLabel" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold mb-0" id="modalVisorPdfLabel">
                    <i class="fa-regular fa-file-pdf me-2"></i>
                    <span class="pdf-nombre-archivo">Soporte</span>
                </h6>
                <button type="button" class="btn-close" id="btnCerrarVisorPdf" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="pdfSpinner" style="display:none;">
                    <div class="spinner-border text-light" role="status" style="width: 3rem; height: 3rem;"><span class="visually-hidden">Cargando...</span></div>
                    <p class="mt-3 text-light small">Cargando documento...</p>
                </div>
                <div id="pdfVisorError" style="display:none;"></div>
                <div id="pdfVisorContenido" style="display:none; flex:1; width:100%;">
                    <iframe id="pdfIframe" src="about:blank"></iframe>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-primary" id="btnDescargarPdf" style="display:none;">
                    <i class="fa-solid fa-download me-1"></i> Descargar
                </button>
                <button type="button" class="btn btn-sm btn-secondary" id="btnCerrarVisorPdfFooter">Cerrar</button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="modalConsultaComboEstructura" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-pantalla-completa">
        <div class="modal-content" style="height: 95vh;">
            <div class="modal-header border-0 pb-0">
                <h1 class="modal-title fs-5 fw-bold" id="tituloConsultaComboEstructura">
                    <i class="fa-solid fa-layer-group text-primary me-2"></i>Estructura del Combo: <span id="lblNombreComboConsulta" class="text-secondary"></span>
                </h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body pt-3 bg-light" style="overflow-y: auto;">
                <div class="table-responsive small border bg-white" style="max-height: calc(95vh - 150px); overflow: auto;">
                    <table class="table table-hover table-bordered table-sm w-auto mb-0" id="tablaConsultaComboEstructura">
                        <thead class="sticky-top text-white text-nowrap" style="z-index: 2;">
                            <tr class="text-center" id="trHeadersConsultaCombo">
                                <th class="table-sticky-col custom-header-cons-bg border-1" style="min-width: 250px; z-index: 3;">Propiedad / Componente</th>
                            </tr>
                        </thead>
                        <tbody class="text-nowrap tabla-items-body">
                            <tr data-campo="art_descripcion"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Descripción</td><td class="align-middle"><input type="text" class="form-control form-control-sm" readonly value="-"></td></tr>
                            <tr data-campo="costo"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Costo</td><td class="align-middle"><input type="text" class="form-control form-control-sm text-end total-combo" readonly value="$ 0.00"></td></tr>
                            <tr data-campo="stock_bodega"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Stock Bodega</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="stock_tienda"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Stock Tiendas</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="inv_optimo"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Inventario Óptimo</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="excedentes_u"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Excedentes (u)</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="excedentes_usd"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Excedentes ($)</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m0_u"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-0 Unidades</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m0_usd"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-0 Dólares</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m1_u"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-1 Unidades</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m1_usd"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-1 Dólares</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m2_u"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-2 Unidades</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m2_usd"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-2 Dólares</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m12_u"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-12 Unidades</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="m12_usd"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">M-12 Dólares</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="igualar_precio"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Igualar Precio</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="dias_antiguedad"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Días de Antigüedad</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="-"></td></tr>
                            <tr data-campo="margen_min_cont"><td class="table-sticky-col align-middle custom-header-cons-bg border-1">Margen mínimo Contado</td><td class="align-middle"><input type="text" class="form-control form-control-sm custom-celda-bg text-end total-combo" readonly value="0%"></td></tr>
