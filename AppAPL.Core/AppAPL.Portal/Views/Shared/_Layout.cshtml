@using Microsoft.AspNetCore.Http

@* 1. Inyectamos los servicios en la parte superior del Layout *@
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject Microsoft.Extensions.Configuration.IConfiguration Config

@{
    // 2. Extraemos los datos directamente de la sesión (sobrevivirán en todas las vistas)
    var session = HttpContextAccessor.HttpContext?.Session;

    var accesosJson = session?.GetString("Accesos") ?? "[]";
    var usuarioAprobadoJson = session?.GetString("usuarioAprobado") ?? "null";
    var moduloFiltroId = Config["Apigee:ModuloFiltroId"] ?? "0";
    var simulate = Config.GetValue<bool>("Apigee:Simulate");
}

@{
    // 2. Extraemos los datos de la sesión y configuración directamente en el Layout
    var httpContext = HttpContextAccessor.HttpContext;


    // Leemos el usuario desde la sesión
    var usuarioActual = Context.Session.GetString("Usuario") ?? "Usuario";
    
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - AppWebAPL</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!--
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />-->

    <link rel="stylesheet" href="~/css/font-awesome/7.2.0/all.min.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/headers.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/sidebars.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/principal.css" asp-append-version="true" />

    <!--  <link rel="stylesheet" href="~/AppWebAPL.styles.css" asp-append-version="true" /> -->

    <link rel="stylesheet" href="~/css/sweetalert2.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@700&display=swap" rel="stylesheet">

    <meta name="theme-color" content="#712cf9">

    <script src="~/js/sweetalert2.all.min.js"></script>
    <script src="~/js/font-awesome/7.2.0/all.js"></script>
    <script src="~/js/jquery-3.7.1.min.js" asp-append-version="true"></script>
</head>

<body>
    <header class="fixed-top">
        <div class="py-2 bg-wine-red border-bottom">
            <div class="container-fluid">
                <div class="d-flex align-items-center justify-content-between">
                    <a href="/" class="d-flex align-items-center text-white text-decoration-none">
                        <!-- 1. Quitamos el 50% y usamos me-3 (margin-end) para dar una separación elegante -->
                        <span class="logo-text me-3">BM</span>
                        <!-- 2. Agregamos la clase text-nowrap para impedir que el texto se divida en dos líneas -->
                        <span class="text-nowrap" style="font-size: 1.25rem; font-weight: bold;">APL Software</span>
                    </a>

                    <a class="dropdown-item text-dark text-right text-white" href="#" style="text-align:right">
                        <b>@usuarioActual</b>
                    </a>

                    <ul class="nav text-small mb-0">

                        <li class="nav-item dropdown">
                            <a href="#" class="nav-link text-white dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                              
                                <i class="fa-regular fa-circle-user fa-2x"></i>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item text-dark text-center bg-warning" href="#">
                                        @usuarioActual
                                    </a>
                                </li>



                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2" href="#">
                                        <i class="fa-regular fa-user text-secondary"></i>
                                        <span id="user_id"></span>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center gap-2" href="#">
                                        <i class="fa-solid fa-desktop"></i>
                                        <span id="ip"></span>
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>


                                <li>
                                    <a class="dropdown-item" asp-controller="Login" asp-action="Logout">
                                        <i class="fa-solid fa-right-from-bracket"></i>
                                        Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <div id="sidebar" class="flex-shrink-0 p-3 scrollarea col-auto" style="transition: all 0.3s; width: 250px;">
                <h5 class="mb-3 fw-bold">Opciones</h5>
                <hr>
                <ul id="menu-dinamico" class="list-unstyled ps-0">                   
                </ul>
            </div>

            <div class="menu-toggle-container col-auto py-2 px-1">

                <button id="toggleMenu" class="btn btn-primary">
                    ☰
                </button>

            </div>
            <main id="mainContent" class="col p-3" style="transition: all 0.3s;">
                @RenderBody()
            </main>
        </div>
    </div>


    <script>
        // 1. Asignamos al objeto 'window' leyendo desde la Sesión del servidor
        window.misAccesos = @Html.Raw(accesosJson);
        window.usuarioAprobado = @Html.Raw(usuarioAprobadoJson);
        window.moduloIdFiltro = "@moduloFiltroId";
        window.simulate = "@simulate";

        // 2. Filtramos usando las variables
        window.accesosFiltrados = window.misAccesos.filter(x => x.ModuloID == window.moduloIdFiltro);


        console.log("✅ Permisos cargados en esta vista:", window.misAccesos);
        console.log("✅ Accesos filtrados:", window.accesosFiltrados);
        console.log("✅ usuarioAprobado:", window.usuarioAprobado);
        console.log("apigee simulado: ", window.simulate);

        // 3. Esperamos a que el DOM esté listo para pintar en los elementos HTML
        document.addEventListener("DOMContentLoaded", function () {
        if (window.usuarioAprobado) {
        $("#user_id").text(window.usuarioAprobado.CodigoUsuario || "Sin Usuario");
        $("#ip").text(window.usuarioAprobado.ip || "IP no detectada");
        } else {
        console.warn("⚠️ No hay usuario aprobado en sesión.");
        }
        });
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.getElementById('toggleMenu').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('hidden');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>

