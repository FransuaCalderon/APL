@* ~/Views/Login/Login.cshtml *@
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "APL System - Login";
    
    // Verificamos si el usuario ya inició sesión en Microsoft (Fase 1 completada)
    bool isSamlAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="login-container">
    <div class="login-card">
        <header class="card-header">
            <div class="logo-box">BM</div>
            <h1 class="system-name">APL System</h1>
        </header>

        @if (!isSamlAuthenticated)
        {
            <form class="login-form" method="get" action="/Auth/Login">
                <div class="form-group">
                    <label>País</label>
                    <select class="form-control" disabled>
                        <option selected>EC - Ecuador</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Empresa</label>
                    <input type="text" class="form-control" value="Artefacta" disabled>
                </div>

                <button type="submit" class="btn btn-primary" style="background-color: #0078D4; border-color: #0078D4;">
                    Iniciar sesión con Microsoft
                </button>
            </form>
        }
        else
        {
            <div id="loadingData" class="text-center" style="margin: 30px 0;">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
                <p id="loadingText" class="mt-3" style="color: #555; font-weight: 500;">Buscando usuarios vinculados...</p>
            </div>

            <form class="login-form" id="legacyForm" style="display:none;">
                <div class="form-group">
                    <label>País</label>
                    <select class="form-control" disabled><option>EC - Ecuador</option></select>
                </div>
                <div class="form-group">
                    <label>Empresa</label>
                    <input type="text" class="form-control" value="Artefacta" disabled>
                </div>

                <div class="form-group">
                    <label for="usuarioLegado">Seleccione su Usuario</label>
                    <div class="input-container select-container">
                        <select id="usuarioLegado" class="form-control" required>
                            <option value="">Cargando usuarios...</option>
                        </select>
                        <span class="select-arrow"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="contrasena">Contraseña</label>
                    <input type="password" id="contrasena" class="form-control" required>
                </div>

                <div id="errorMsg" class="alert alert-danger" style="display:none; font-size: 14px; margin-bottom: 15px;"></div>

                <button type="submit" id="btnIngresar" class="btn btn-primary" disabled>Validando...</button>
            </form>

            <div class="text-center mt-3">
                <a href="/Auth/Logout" class="text-muted" style="font-size: 12px;">Ingresar con otra cuenta de Microsoft</a>
            </div>
        }

        <!--
        <div class="language-switch">
            <span>Cambiar idioma:</span>
            <select class="language-select"><option value="es" selected>ES</option><option value="en">EN</option></select>
        </div>-->
    </div>
</div>

@if (isSamlAuthenticated)
{

    @section Scripts{
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script>
            $(document).ready(function () {
            var $form = $("#legacyForm");
            var $loader = $("#loadingData");
            var $loaderText = $("#loadingText");
            var $errorMsg = $("#errorMsg");

            var ipCLiente = null;


            async function obtenerIpCliente() {
            try {
            // Recuerda cambiar la URL por la ruta real o puerto de tu API en .NET 9
            const response = await $.ajax({
            url: '/api/mi-ip',
            type: 'GET',
            dataType: 'json'
            });

            // Retornamos directamente el valor que vino del JSON {"ip": "::1"}
            return response.ip;

            } catch (error) {
            console.error("Error al consumir el endpoint consultar ip:", error);
            return null;
            }
            }


            obtenerIpCliente().then(ip => {
                if (ip) {
                    
                    ipCLiente = ip;
                    console.log("IP retornada:", ipCLiente);
                }
            });

            // 1. Capturamos el Emisor Válido desde el servidor
            var emisorIdValido = '@ViewBag.EmisorIdValido';

            // 1. Consultar usuarios en Apigee usando el correo del claim SAML
            $.ajax({
            url: "/api/consultar-usuario",
            method: "GET"
            }).done(function (lista) {
            console.log("lista usuarios: ", lista);

            //prueba para simular un solo usuario
            /*
            const lista = listaapi.filter((item, indice) => indice == 0);
            console.log("lista: ", lista);*/

            if (lista && lista.length === 1) {
            // ==========================================
            // CASO 1: UN SOLO USUARIO (Auto-Login)
            // ==========================================
            $loaderText.text("Usuario detectado. Cargando accesos...");

            var u = lista[0];

            u.ip = ipCLiente;
            var nombreSeleccionado = u.NombreUsuario;
            // Extraemos el ID directamente del primer usuario de la lista
            //var usuarioId = u.UsuarioID || u.UsuarioId || u.id || u.CodigoUsuario;
            var usuarioId = u.CodigoInterno;

            // Saltamos directo a cargar accesos
            cargarAccesosYRedirigir(usuarioId, nombreSeleccionado, u);

            } else if (lista && lista.length > 1) {
            // ==========================================
            // CASO 2: MÚLTIPLES USUARIOS (Mostrar Combo)
            // ==========================================
            var $select = $("#usuarioLegado");
            $select.empty();

            lista.forEach(function (u) {
            u.ip = ipCLiente;
            $select.append(`<option value="${u.CodigoUsuario}">${u.NombreUsuario}</option>`);
            });

            // Ocultamos el loader y mostramos el formulario
            $loader.hide();
            $form.fadeIn();
            $("#btnIngresar").prop("disabled", false).text("Ingresar");

            } else {
            // ==========================================
            // CASO 3: CERO USUARIOS
            // ==========================================
            $loader.hide();
            $form.fadeIn();
            $errorMsg.text("No se encontraron usuarios legados para su correo.").show();
            $("#btnIngresar").text("Sin acceso");
            }
            }).fail(function () {
            $loader.hide();
            $form.fadeIn();
            $errorMsg.text("Error al consultar el sistema legado en Apigee.").show();
            $("#btnIngresar").text("Error de conexión");
            });

            // 2. Enviar contraseña al LegadosController (SOLO SE EJECUTA SI HUBO > 1 USUARIO)
            $form.on("submit", function (e) {
            e.preventDefault();
            $("#btnIngresar").prop("disabled", true).text("Comprobando credenciales...");
            $errorMsg.hide();

            var codigoSeleccionado = $("#usuarioLegado").val();
            var nombreSeleccionado = $("#usuarioLegado option:selected").text();

            var payload = {
            codigoUsuario: codigoSeleccionado,
            password: $("#contrasena").val()
            };

            // Paso A: Validar credenciales de la contraseña manual
            $.ajax({
            url: "/api/obtener-usuario",
            method: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload)
            }).done(function (usuarioAprobado) {
            console.log("usuarioAprobado", usuarioAprobado);


            // Buscamos el EmisorID en la respuesta (Ajusta 'EmisorID' si en tu JSON viene en minúsculas)
            var emisorUsuario = usuarioAprobado.EmisorID || usuarioAprobado.emisorID ||
            (usuarioAprobado[0] && (usuarioAprobado[0].EmisorID || usuarioAprobado[0].emisorID));

            // 🔴 VALIDACIÓN DEL EMISOR 🔴
            // Convertimos ambos a String por seguridad antes de comparar
            if (String(emisorUsuario) !== String(emisorIdValido)) {
            $errorMsg.text("Acceso denegado: El usuario no pertenece al emisor autorizado.").show();
            $("#btnIngresar").prop("disabled", false).text("Ingresar");
            return; // Detenemos la ejecución aquí, no avanza al Home
            }



            var usuarioId = usuarioAprobado.UsuarioID || usuarioAprobado.UsuarioId ||
            (usuarioAprobado[0] && usuarioAprobado[0].UsuarioId) || usuarioAprobado.id;

            $("#btnIngresar").text("Cargando accesos y permisos...");

            // Cargar accesos
            cargarAccesosYRedirigir(usuarioId, nombreSeleccionado, usuarioAprobado);

            }).fail(function (xhr) {
            var msg = (xhr.responseJSON && xhr.responseJSON.error) ? xhr.responseJSON.error : "Usuario o contraseña inválidos.";
            $errorMsg.text(msg).show();
            $("#btnIngresar").prop("disabled", false).text("Ingresar");
            });
            });

            // ==========================================
            // FUNCIÓN REUTILIZABLE: Cargar Accesos y Redirigir
            // ==========================================
            function cargarAccesosYRedirigir(usuarioId, nombreSeleccionado, usuarioAprobado) {
            $.ajax({
            url: "/api/accesos",
            method: "POST",
            contentType: "application/json",
            data: JSON.stringify({ usuarioId: usuarioId })
            }).done(function (listaAccesos) {

            console.log("listaAccesos: ", listaAccesos);

            // Enviar datos finales a la sesión de .NET
            $.post("/Login/EstablecerSesionLegada", {
            nombreUsuario: nombreSeleccionado,
            accesos: JSON.stringify(listaAccesos),
            usuarioAprobado: JSON.stringify(usuarioAprobado)
            }).done(function () {
            window.location.href = "/Home/Index";
            });

            }).fail(function () {
            $loader.hide();
            $form.show();
            $errorMsg.text("Error al cargar los permisos y accesos del sistema.").show();
            $("#btnIngresar").prop("disabled", false).text("Ingresar");
            });
            
            

            }



            });

        </script>
    
    
    }


   
}