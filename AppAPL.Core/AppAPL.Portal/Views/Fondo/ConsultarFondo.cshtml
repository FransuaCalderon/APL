@{
    ViewData["Title"] = "Consulta de Fondos";
}

@{
    // Viene del ViewBag que llenamos en el controlador
    var usuarioActual = ViewBag.UsuarioActual as string;
}

@section Scripts {
    <script>
        // Variable global con el usuario logueado
        window.usuarioActual = '@usuarioActual';
    </script>
    <script src="~/js/jquery-3.7.1.min.js" asp-append-version="true"></script>
    <script src="~/js/Fondo/ConsultarFondo.js" asp-append-version="true"></script>
    <script src="~/js/datatables.min.js" asp-append-version="true"></script>
}

<style>
    /* Estilos exactos de ConsultarPromocion para los iconos */
    .promo-icons {
        display: flex;
        flex-direction: row; /* Fuerza a que estén horizontales */
        flex-wrap: nowrap;
        gap: 4px;
    }

    .promo-icon-btn {
        width: 28px;
        height: 28px;
        border: 1px solid #bbb;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 2px;
        color: #555;
        font-size: 0.8rem;
        cursor: pointer;
        transition: background 0.2s;
    }

    .promo-icon-btn:hover {
        background: #e8e8e8;
        color: #333;
    }

    /* MODAL TABLAS LOG/APROBACIONES */
    #tablaLog thead tr:first-child th, #tablaAprobaciones thead tr:first-child th {
        background-color: #8B0000 !important;
        color: #fff;
        text-align: center;
        font-weight: bold;
        padding: 8px;
        font-size: 0.95rem;
    }

    #tablaLog thead tr:nth-child(2) th, #tablaAprobaciones thead tr:nth-child(2) th {
        background-color: #1a237e !important;
        color: #fff;
        text-align: center;
        white-space: nowrap;
    }
</style>
<h2 class="titulo-fondos">Consulta - Fondos</h2>
<hr class="separador-fondos" />

<link rel="stylesheet" href="~/css/datatables.css" asp-append-version="true" />

<div class="table-responsive" style="margin-top:0; padding-top:0;">
    <div id="tabla">
    </div>
</div>

<!-- Modal Personalizado -->
<div id="modalVisualizarFondo" class="custom-modal">
    <div class="custom-modal-overlay"></div>
    <div class="custom-modal-container">
        <div class="custom-modal-header">
            <h5 class="custom-modal-title">Visualizar Datos de Fondo</h5>
            <button type="button" class="custom-modal-close" onclick="cerrarModalFondo()">&times;</button>
        </div>

        <div class="custom-modal-body">
            <form id="formEditarFondo">
                <input type="hidden" id="modal-idOpcion" name="idOpcion">

                <!-- PRIMERA FILA -->
                <div class="custom-form-row">
                    <div class="custom-form-col">
                        <label class="custom-label">ID Fondo</label>
                        <input type="text" class="custom-input" id="modal-fondo-id" name="idfondo" disabled>
                    </div>
                    <div class="custom-form-col">
                        <label class="custom-label">Descripción <span class="text-danger"></span></label>
                        <input type="text" class="custom-input" id="modal-fondo-descripcion" name="descripcion" disabled>
                    </div>
                    <div class="custom-form-col">
                        <label class="custom-label">Proveedor <span class="text-danger"></span></label>
                        <input type="text" class="custom-input" id="modal-fondo-proveedor" name="proveedor" disabled>
                    </div>
                    <div class="custom-form-col">
                        <label class="custom-label">Tipo de Fondo <span class="text-danger"></span></label>
                        <input type="text" class="custom-input" id="modal-fondo-tipofondo" name="tipo_fondo" disabled>
                    </div>
                </div>

                <!-- SEGUNDA FILA -->
                <div class="custom-form-row">
                    <div class="custom-form-col">
                        <label class="custom-label">Fecha Inicio <span class="text-danger"></span></label>
                        <input type="date" class="custom-input" id="modal-fondo-fechainicio" name="fecha_inicio" disabled>
                    </div>
                    <div class="custom-form-col">
                        <label class="custom-label">Fecha Fin <span class="text-danger"></span></label>
                        <input type="date" class="custom-input" id="modal-fondo-fechafin" name="fecha_fin" disabled>
                    </div>
                    <div class="custom-form-col">
                        <label class="custom-label">Valor Fondo <span class="text-danger"></span></label>
                        <!-- ✅ CAMBIO DE type="number" A type="text" -->
                        <input type="text" class="custom-input" id="modal-fondo-valor" name="valor_fondo" disabled>
                    </div>
                    <div class="custom-form-col">
                        <label class="custom-label">Estado</label>
                        <input type="text" class="custom-input" id="modal-fondo-estado" name="estado" disabled>
                    </div> 
                </div>

                <div class="custom-form-row" style="display: flex; align-items: flex-end; gap: 10px;">
                    <div class="custom-form-col" style="flex: 1;">
                        <label class="custom-label">Valor Disponible</label>
                        <input type="text" class="custom-input" id="modal-fondo-disponible" name="valor_disponible" disabled>
                    </div>
                    <div class="custom-form-col" style="flex: 1;">
                        <label class="custom-label">Valor Comprometido</label>
                        <input type="text" class="custom-input" id="modal-fondo-comprometido" name="valor_comprometido" disabled>
                    </div>
                    <div class="custom-form-col" style="flex: 1;">
                        <label class="custom-label">Valor Liquidado</label>
                        <input type="text" class="custom-input" id="modal-fondo-liquidado" name="valor_liquidado" disabled>
                    </div>
    
                    <div class="custom-form-col" style="flex: 0 0 auto; padding-bottom: 2px;">
                        <div class="promo-icons">
                            <div class="promo-icon-btn" id="btnVerLogFondo" title="Registro de Log">
                                <i class="fa-regular fa-rectangle-list"></i>
                            </div>
                            <div class="promo-icon-btn" id="btnVerAprobacionesFondo" title="Registro de Aprobaciones">
                                <i class="fa-regular fa-calendar-check"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <hr class="custom-divider">

            <!-- SECCIÓN TABLA -->
            <h5 class="custom-section-title">
                <i class="fa-solid fa-file-contract"></i> Datos del Acuerdo Asociado
            </h5>
            <div class="custom-table-container">
                <div id="tabla-acuerdo-fondo"></div>
            </div>
        </div>

        <div class="custom-modal-footer">
            <button type="button" class="custom-btn-secondary" onclick="cerrarModalFondo()">
                Cerrar
            </button>
        </div>
    </div>
</div>

<div class="modal fade" id="modalRegistroLog" tabindex="-1" aria-labelledby="modalLogLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title fw-bold" id="modalLogLabel"><i class="fa-regular fa-rectangle-list me-2"></i>Registro de Log</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-2">
                <div id="logSpinner" class="text-center py-4" style="display:none;">
                    <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Cargando...</span></div>
                    <p class="mt-2 text-muted small">Cargando registros...</p>
                </div>
                <div id="contenedorTablaLog" style="display:none;">
                    <div class="table-responsive">
                        <table id="tablaLog" class="table table-bordered table-hover table-sm mb-0">
                            <thead>
                                <tr><th colspan="8">Registro de Log</th></tr>
                                <tr><th>IdLog</th><th>Fecha</th><th>Usuario</th><th>Opción</th><th>Acción</th><th>Entidad</th><th>Tipo Proceso</th><th>Datos</th></tr>
                            </thead>
                            <tbody id="tbodyLog"></tbody>
                        </table>
                    </div>
                    <div id="logSinDatos" class="alert alert-info text-center mt-2" style="display:none;">No se encontraron registros de log para esta promoción.</div>
                </div>
            </div>
            <div class="modal-footer py-2"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button></div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalRegistroAprobaciones" tabindex="-1" aria-labelledby="modalAprobacionesLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title fw-bold" id="modalAprobacionesLabel"><i class="fa-regular fa-calendar-check me-2"></i>Registro de Aprobaciones</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-2">
                <div id="aprobacionesSpinner" class="text-center py-4" style="display:none;">
                    <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Cargando...</span></div>
                    <p class="mt-2 text-muted small">Cargando registros...</p>
                </div>
                <div id="contenedorTablaAprobaciones" style="display:none;">
                    <div class="table-responsive">
                        <table id="tablaAprobaciones" class="table table-bordered table-hover table-sm mb-0">
                            <thead>
                                <tr><th colspan="8">Registro de Aprobaciones</th></tr>
                                <tr><th>Tipo Solicitud</th><th>Usuario Solicita</th><th>Fecha Solicitud</th><th>Usuario Aprobador</th><th>Fecha Aprobación</th><th>Nivel</th><th>Estado</th><th>Lote</th></tr>
                            </thead>
                            <tbody id="tbodyAprobaciones"></tbody>
                        </table>
                    </div>
                    <div id="aprobacionesSinDatos" class="alert alert-info text-center mt-2" style="display:none;">No se encontraron registros de aprobaciones para esta promoción.</div>
                </div>
            </div>
            <div class="modal-footer py-2"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cerrar</button></div>
        </div>
    </div>
</div>
